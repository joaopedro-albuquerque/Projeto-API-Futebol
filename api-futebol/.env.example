API_KEY=your_api_key_here
PORT=3000
NODE_ENV=development

# Local development (public Railway proxy)
DATABASE_URL_LOCAL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_PUBLIC_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Railway runtime (private network placeholders)
DATABASE_URL=postgresql://${{PGUSER}}:${{POSTGRES_PASSWORD}}@${{RAILWAY_PRIVATE_DOMAIN}}:5432/${{PGDATABASE}}
